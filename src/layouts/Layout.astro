---
interface Props {
	title?: string;
}

const { title = 'Astro App' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="A minimal developer-style landing page with a bright futuristic presence."
		/>
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}

	:global(html) {
		scroll-behavior: smooth;
	}

	:global(body) {
		min-height: 100vh;
	}
</style>
